{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "github>mbologna/renovate-config"
  ],
  "customManagers": [
    {
      "description": "Track ARG versions in Dockerfile annotated with inline renovate comments",
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>[^\\s]+)\\s+depName=(?<depName>[^\\s]+)\\s*\\n(?:#[^\\n]*\\n)?ARG [A-Z_]+=(?<currentValue>[^\\s]+)"
      ]
    }
  ]
}
