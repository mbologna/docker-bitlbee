# User/Group IDs for volume permissions
UID=1000
GID=1000

# Port mappings
BITLBEE_PORT=6697

# Timezone
TZ=UTC

# Optional: fix the Matrix registration token used to create accounts on the
# built-in conduwuit homeserver. If unset, a random token is generated on first
# run and printed to the container logs.
# MATRIX_REGISTRATION_TOKEN=change-me-to-something-secret
